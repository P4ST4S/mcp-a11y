{
  "name": "mcp-a11y",
  "version": "0.1.0",
  "description": "MCP server for web accessibility remediation — the USB-C port of accessibility. Audits pages against WCAG (axe-core, deterministic) and applies fixes.",
  "type": "module",
  "bin": {
    "mcp-a11y": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "inspect": "pnpm dlx @modelcontextprotocol/inspector tsx src/index.ts",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "accessibility",
    "a11y",
    "wcag",
    "axe-core"
  ],
  "author": "Antoine",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@axe-core/playwright": "^4.11.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "node-html-parser": "^7.1.0",
    "octokit": "^5.0.5",
    "playwright": "^1.60.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}

# Anthropic API key — used ONLY by generate_alt_text (vision model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub token — used ONLY by open_pr (Octokit)
GITHUB_TOKEN=your_github_token_here

# STRICT GUARDRAIL: the only repo open_pr is ever allowed to touch.
# Format: owner/repo
A11Y_TARGET_REPO=your_org/your-demo-repo
